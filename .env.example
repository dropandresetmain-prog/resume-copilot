# Supabase (public anon key only — never commit service role key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# After creating a Supabase project:
# 1. Run supabase/schema.sql in the SQL editor
# 2. Enable Email auth (password and/or magic link)
# 3. Add redirect URLs under Authentication → URL Configuration:
#    - http://localhost:3000/**
#    - https://your-production-domain.vercel.app/**
# 4. On Vercel, set the same NEXT_PUBLIC_* vars in Project Settings → Environment Variables

# AI provider configuration (placeholder values only — never commit real keys)
AI_PROVIDER=mock
GEMINI_API_KEY=
# Optional legacy/dev overrides for fixed flows only (enrichment, company context).
# They do NOT override user-selected resume/cover-letter generation tiers in the UI.
# Defaults when unset: gemini-2.5-flash primary, gemini-2.5-flash-lite fallback.
GEMINI_MODEL_PRIMARY=
GEMINI_MODEL_FALLBACK=
# Firecrawl — server-side company website research only (never expose client-side)
FIRECRAWL_API_KEY=
OPENAI_API_KEY=
